    "allure-commandline": "^2.40.0",
    "allure-playwright": "^3.7.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@playwright/cli": "^0.1.13",
    "dotenv": "^17.4.2"
  }
