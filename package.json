  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:qa": "NODE_ENV=qa npm run test",
    "test:uat": "NODE_ENV=uat npm run test",
    "test:stage": "NODE_ENV=stage npm run test",
    "smoke": "playwright test --grep @smoke",
    "regression": "playwright test --grep @regression",
    "api": "playwright test --grep @api",
    "allure": "allure serve allure-results",
    "allure:clear": "rm -rf allure-report allure-results",
    "html": "npx playwright show-report"
  },
